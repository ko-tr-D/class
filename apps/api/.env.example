# Local development fallback uses SQLite when DATABASE_URL is empty.
# For Supabase, paste the Session pooler connection string from Project Settings > Database > Connection string.
DATABASE_URL=

# Future deployment values
APP_ENV=development
WEB_ORIGIN=http://127.0.0.1:4173

# Supabase Storage is optional for the next step.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=class-documents
